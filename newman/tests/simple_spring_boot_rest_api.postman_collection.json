	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const workflow = pm.environment.get('workflow').split(',').filter(Boolean); // get workflow array, remove empty strings",
					"",
					"let currentRequest = pm.info.requestName; // nome do request atual",
					"let idx = workflow.indexOf(currentRequest); // id do request no workflow",
					"",
					"let next = (idx >= 0 && idx < workflow.length - 1) ? workflow[idx + 1] : null;  // pega nome do proximo request no workflow ",
					"",
					"console.log((next)?`next: ${next}`:'end tests'); // loga o proximo request na console",
					"if (next) pm.execution.setNextRequest(next); // seta o proximo request",
					"else pm.execution.setNextRequest(null);"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (!pm.info.requestName.includes(\" - \")) {",
					"    pm.test(`${pm.info.requestName} - OK` , () => {",
					"        pm.response.to.have.status(200); // realiza a valisacao do status OK paracada um dos requests",
					"    });",
					"}"
				]
			}
		}
